{
  "name": "@gaubee/dweb-cloud-workspace",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev:server": "cargo run -p dweb-cloud-server -- --http 127.0.0.1:9080 --data-dir ./.data",
    "build:rust": "cargo build --workspace",
    "check:rust": "cargo test --workspace",
    "docker:build": "docker build -t gaubee/dweb-cloud:local .",
    "docker:up": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f dweb-cloud",
    "docker:down": "docker compose down",
    "docker:publish": "./scripts/publish-docker.sh",
    "docker:publish:version": "./scripts/publish-docker.sh"
  }
}
